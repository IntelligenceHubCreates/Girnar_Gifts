# ── Site / Brand ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME=Girnar Gifts
NEXT_PUBLIC_SITE_URL=https://girnargifts.com

# ── Backend API ──────────────────────────────────────────────────────────────
# Your Girnar Gifts backend URL — change this to your deployed backend
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE=http://localhost:8000

# ── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate a secret: openssl rand -base64 32 (never reuse Little Loot's)
NEXTAUTH_SECRET=your-nextauth-secret-change-this

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Get from: https://console.cloud.google.com — Girnar needs its own OAuth app
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Razorpay ─────────────────────────────────────────────────────────────────
# Girnar's own Razorpay account/keys (test mode to start) — never reuse Little Loot's
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id_here
